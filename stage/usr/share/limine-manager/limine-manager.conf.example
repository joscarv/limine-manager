[manager]
schema_version = 1

[system]
boot_mount = /boot
limine_config = /boot/limine.conf
kernel_cmdline_file = /etc/kernel/cmdline
modules_root = /usr/lib/modules
cpuinfo = /proc/cpuinfo
mkinitcpio_config = /etc/mkinitcpio.conf

[snapper]
config = root
snapshots_subvolume = @snapshots
snapshots_directory = /.snapshots
max_snapshots = 0
include_read_write = false

[backups]
retain = 5

[menu]
root_title = Arch Linux
snapshots_title = Snapshots
root_expanded = true
snapshots_expanded = false

[kernels]
include =
exclude =
order =

[theme]
# Built-in presets: none, tokyo-night, catppuccin, nord, dracula, gruvbox
name = none

[automation]
enabled = true
snapper = true
pacman = true
debounce_seconds = 3
runtime_directory = /run/limine-manager

[limine]
timeout = 5
remember_last_entry = yes

[secure_boot]
# Protect limine.conf and traditional kernel resources when Secure Boot is active.
protect_config = true
# Keep false for the first manual apply and reboot test. Enable afterwards so
# Snapper/Pacman-triggered refreshes may enroll and re-sign Limine automatically.
automatic_apply = false
# auto searches common Limine EFI locations below boot_mount.
efi_executable = auto
